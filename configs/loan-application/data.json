{
  "fields": [
    {
      "id": "applicant_name",
      "type": "string",
      "maxLength": 100,
      "nullable": false
    },
    {
      "id": "date_of_birth",
      "type": "date",
      "format": "DD/MM/YYYY",
      "nullable": false
    },
    {
      "id": "pan_number",
      "type": "string",
      "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
      "nullable": false
    },
    {
      "id": "aadhaar_number",
      "type": "string",
      "pattern": "^[0-9]{12}$",
      "nullable": false
    },
    {
      "id": "loan_type",
      "type": "enum",
      "source": "static",
      "options": [
        { "value": "PERSONAL", "label": "Personal Loan" },
        { "value": "HOME",     "label": "Home Loan" },
        { "value": "VEHICLE",  "label": "Vehicle Loan" },
        { "value": "EDUCATION","label": "Education Loan" }
      ],
      "nullable": false
    },
    {
      "id": "loan_amount",
      "type": "currency",
      "currency": "INR",
      "min": 10000,
      "max": 10000000,
      "nullable": false
    },
    {
      "id": "loan_tenure_months",
      "type": "integer",
      "min": 6,
      "max": 360,
      "nullable": false
    },
    {
      "id": "annual_income",
      "type": "currency",
      "currency": "INR",
      "min": 0,
      "nullable": false
    },
    {
      "id": "employment_type",
      "type": "enum",
      "source": "static",
      "options": [
        { "value": "SALARIED",    "label": "Salaried" },
        { "value": "SELF_EMPLOYED","label": "Self Employed" },
        { "value": "BUSINESS",    "label": "Business Owner" }
      ],
      "nullable": false
    },
    {
      "id": "employer_name",
      "type": "string",
      "maxLength": 150,
      "nullable": true
    },
    {
      "id": "property_value",
      "type": "currency",
      "currency": "INR",
      "min": 0,
      "nullable": true
    },
    {
      "id": "property_address",
      "type": "text",
      "maxLength": 500,
      "nullable": true
    },
    {
      "id": "co_applicant_name",
      "type": "string",
      "maxLength": 100,
      "nullable": true
    },
    {
      "id": "nominee_name",
      "type": "string",
      "maxLength": 100,
      "nullable": true
    },
    {
      "id": "co_applicant_pan",
      "type": "string",
      "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
      "nullable": true
    },
    {
      "id": "kyc_consent",
      "type": "boolean",
      "nullable": false
    },
    {
      "id": "declaration_consent",
      "type": "boolean",
      "nullable": false
    }
  ]
}
