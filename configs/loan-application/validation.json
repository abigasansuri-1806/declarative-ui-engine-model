{
  "rules": [
    {
      "fieldId": "applicant_name",
      "required": true,
      "constraints": [
        {
          "type": "minLength",
          "value": 2,
          "message": "applicant_name.minLength"
        },
        {
          "type": "pattern",
          "value": "^[a-zA-Z\\s]+$",
          "message": "applicant_name.invalidChars"
        }
      ]
    },
    {
      "fieldId": "date_of_birth",
      "required": true,
      "constraints": [
        {
          "type": "minAge",
          "value": 21,
          "message": "date_of_birth.minAge"
        },
        {
          "type": "maxAge",
          "value": 65,
          "message": "date_of_birth.maxAge"
        }
      ]
    },
    {
      "fieldId": "pan_number",
      "required": true,
      "constraints": [
        {
          "type": "pattern",
          "value": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
          "message": "pan_number.invalidFormat"
        },
        {
          "type": "remote",
          "endpoint": "/api/validate/pan",
          "trigger": "onBlur",
          "debounce": 500,
          "message": "pan_number.invalidPan"
        }
      ]
    },
    {
      "fieldId": "aadhaar_number",
      "required": true,
      "constraints": [
        {
          "type": "exactLength",
          "value": 12,
          "message": "aadhaar_number.invalidLength"
        },
        {
          "type": "luhn",
          "message": "aadhaar_number.invalidChecksum"
        }
      ]
    },
    {
      "fieldId": "loan_amount",
      "required": true,
      "constraints": [
        {
          "type": "min",
          "value": 10000,
          "message": "loan_amount.min"
        },
        {
          "type": "max",
          "value": 10000000,
          "message": "loan_amount.max"
        },
        {
          "type": "crossField",
          "rule": {
            "left": "loan_amount",
            "operator": "<=",
            "right": {
              "field": "annual_income",
              "multiply": 60
            }
          },
          "message": "loan_amount.exceedsEligibility"
        }
      ]
    },
    {
      "fieldId": "loan_tenure_months",
      "required": true,
      "constraints": [
        {
          "type": "conditional",
          "when": "loan_type == HOME",
          "then": {
            "type": "min",
            "value": 12,
            "message": "loan_tenure_months.homeLoanMin"
          }
        },
        {
          "type": "conditional",
          "when": "loan_type == PERSONAL",
          "then": {
            "type": "max",
            "value": 60,
            "message": "loan_tenure_months.personalLoanMax"
          }
        }
      ]
    },
    {
      "fieldId": "annual_income",
      "required": true,
      "constraints": [
        {
          "type": "min",
          "value": 180000,
          "message": "annual_income.min"
        }
      ]
    },
    {
      "fieldId": "employment_type",
      "required": true,
      "constraints": []
    },
    {
      "fieldId": "employer_name",
      "required": false,
      "constraints": [
        {
          "type": "requiredWhen",
          "when": "employment_type == SALARIED",
          "message": "employer_name.requiredForSalaried"
        }
      ]
    },
    {
      "fieldId": "property_value",
      "required": false,
      "constraints": [
        {
          "type": "requiredWhen",
          "when": "loan_type == HOME",
          "message": "property_value.requiredForHomeLoan"
        },
        {
          "type": "conditionalMin",
          "when": "loan_type == HOME",
          "value": {
            "field": "loan_amount",
            "multiply": 1.2
          },
          "message": "property_value.belowLoanAmount"
        }
      ]
    },
    {
      "fieldId": "property_address",
      "required": false,
      "constraints": [
        {
          "type": "requiredWhen",
          "when": "loan_type == HOME",
          "message": "property_address.requiredForHomeLoan"
        }
      ]
    },
    {
      "fieldId": "co_applicant_name",
      "required": false,
      "constraints": []
    },
    {
      "fieldId": "co_applicant_pan",
      "required": false,
      "constraints": [
        {
          "type": "requiredWhen",
          "when": "co_applicant_name != null",
          "message": "co_applicant_pan.requiredWithName"
        },
        {
          "type": "notEqualTo",
          "value": "pan_number",
          "message": "co_applicant_pan.sameAsPrimary"
        }
      ]
    },
    {
      "fieldId": "kyc_consent",
      "required": true,
      "constraints": [
        {
          "type": "mustBeTrue",
          "message": "kyc_consent.required"
        }
      ]
    },
    {
      "fieldId": "declaration_consent",
      "required": true,
      "constraints": [
        {
          "type": "mustBeTrue",
          "message": "declaration_consent.required"
        }
      ]
    },
    {
      "fieldId": "nominee_name",
      "required": false,
      "constraints": [
        {
          "type": "minLength",
          "value": 2,
          "message": "nominee_name.minLength"
        },
        {
          "type": "requiredWhen",
          "when": "loan_type == HOME",
          "message": "nominee_name.requiredForHomeLoan"
        }
      ]
    }
  ]
}